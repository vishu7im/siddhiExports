# =============================================================================
# EmailJS credentials for the contact / quote form
# -----------------------------------------------------------------------------
# These are PUBLIC, browser-safe identifiers — your SMTP password is NEVER here.
# It lives only inside your EmailJS dashboard. See README.md "Email setup".
#
# Local dev:  copy this file to ".env" and fill in the 3 values below.
# GitHub Pages build: add the same 3 keys as repository
#   Settings → Secrets and variables → Actions → "Variables" (not Secrets,
#   since they must be readable at build time).
# =============================================================================

PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
