---
import { site, navLinks, whatsappLink } from "../data/site";
import Icon from "./Icon.astro";
const current = Astro.url.pathname;
---

<header class="hdr">
  <div class="container hdr__inner">
    <a href="/" class="brand" aria-label={`${site.name} home`}>
      <img
        src="/logo.png"
        class="brand__logo"
        width="91"
        height="48"
        alt={`${site.name} logo`}
      />
      <span class="brand__name">Siddhi<span>Exports</span></span>
    </a>

    <nav class="nav" id="nav" aria-label="Primary">
      {
        navLinks.map((l) => (
          <a
            href={l.href}
            class:list={["nav__link", { "is-active": current === l.href }]}
          >
            {l.label}
          </a>
        ))
      }
      <a href="/get-quote" class="btn btn--primary nav__cta">Get Quote</a>
    </nav>

    <div class="hdr__actions">
      <a
        href={whatsappLink()}
        class="btn btn--whatsapp hdr__wa"
        target="_blank"
        rel="noopener"
      >
        <Icon name="whatsapp" />
        <span>WhatsApp</span>
      </a>
      <button
        class="hamburger"
        id="hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 68px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--navy);
  }
  .brand__logo {
    height: 48px;
    width: auto;
  }
  .brand__name span {
    color: var(--orange-600);
  }
  @media (max-width: 420px) {
    .brand__logo {
      height: 40px;
    }
    .brand__name {
      font-size: 1.1rem;
    }
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .nav__link {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: 0.98rem;
    color: var(--ink);
    padding: 0.5rem 0.8rem;
    border-radius: 8px;
  }
  .nav__link:hover {
    background: var(--bg-soft);
    color: var(--navy);
  }
  .nav__link.is-active {
    color: var(--orange-600);
  }
  .nav__cta {
    margin-left: 0.6rem;
    padding: 0.6rem 1.2rem;
  }

  .hdr__actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex: none;
  }
  .hdr__wa {
    padding: 0.6rem 1rem;
  }
  .hdr__wa :global(svg) {
    width: 20px;
    height: 20px;
    flex: none;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 8px;
    cursor: pointer;
  }
  .hamburger span {
    width: 26px;
    height: 3px;
    background: var(--navy);
    border-radius: 3px;
    transition:
      transform 0.2s,
      opacity 0.2s;
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Mobile */
  @media (max-width: 940px) {
    .nav__cta {
      display: none;
    }
    .hdr__wa span {
      display: none;
    }
    .hdr__wa {
      padding: 0.6rem;
    }
    .hamburger {
      display: flex;
    }

    .nav {
      position: fixed;
      inset: 68px 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: #fff;
      border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow-lg);
      padding: 0.5rem var(--gutter) 1.2rem;
      transform: translateY(-120%);
      transition: transform 0.25s ease;
      max-height: calc(100vh - 68px);
      overflow-y: auto;
    }
    .nav.is-open {
      transform: translateY(0);
    }
    .nav__link {
      padding: 0.85rem 0.4rem;
      border-bottom: 1px solid var(--line);
      border-radius: 0;
    }
    .nav__cta {
      display: inline-flex;
      margin: 1rem 0 0;
    }
  }
</style>

<script>
  const btn = document.getElementById("hamburger");
  const nav = document.getElementById("nav");
  btn?.addEventListener("click", () => {
    const open = nav?.classList.toggle("is-open");
    btn.setAttribute("aria-expanded", String(!!open));
  });
  // Close menu when a link is tapped
  nav?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      nav.classList.remove("is-open");
      btn?.setAttribute("aria-expanded", "false");
    }),
  );
</script>
