---
import { countryDetails } from '../data/site';
---
<section class="section section--soft" id="countries">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Global Reach</span>
      <h2>Countries We Ship To from India</h2>
      <p>
        Our international parcel delivery network covers the destinations Indian
        families, students and businesses ship to most.
      </p>
    </div>
    <div class="grid grid-2 ctry-grid">
      {countryDetails.map((c) => (
        <article class="card ctry" id={`ship-to-${c.id}`}>
          <header class="ctry__head">
            <img
              src={c.flag}
              width="56"
              height="38"
              alt={c.alt}
              loading="lazy"
            />
            <h3>{c.heading}</h3>
          </header>
          <p>{c.text}</p>
          <a class="ctry__link" href="/get-quote">
            Get a quote for {c.heading.replace('Parcel Service to ', '').replace(' from India', '')} →
          </a>
        </article>
      ))}
    </div>
    <p class="countries__cta">
      Don’t see your destination? <a href="/contact">Contact us</a> or
      <a href="/get-quote">request a free shipping quote online</a> — we ship to
      many more countries on request.
    </p>
  </div>
</section>

<style>
  .ctry {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .ctry__head {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .ctry__head img {
    border-radius: 4px;
    box-shadow: 0 2px 6px rgba(11, 60, 93, 0.15);
    flex: none;
  }
  .ctry__head h3 {
    margin: 0;
    font-size: 1.12rem;
    color: var(--navy);
  }
  .ctry p {
    margin: 0;
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.65;
    flex: 1;
  }
  .ctry__link {
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--orange-600);
  }
  .countries__cta {
    text-align: center;
    margin-top: 1.8rem;
    font-weight: 500;
    color: var(--muted);
  }
  .countries__cta a {
    font-weight: 600;
    color: var(--orange-600);
  }
</style>
