// Icons drawn as solid glyphs (filled with currentColor) instead of strokes.
const filledIcons = new Set(['whatsapp']);
const isFilled = filledIcons.has(name);

const inner = paths[name] ?? '';
---
<svg
  class={cls}
  viewBox="0 0 24 24"
  fill={isFilled ? 'currentColor' : 'none'}
  stroke={isFilled ? 'none' : 'currentColor'}
  stroke-width={isFilled ? undefined : '1.8'}
  stroke-linecap={isFilled ? undefined : 'round'}
  stroke-linejoin={isFilled ? undefined : 'round'}
  aria-hidden="true"
  set:html={inner}
/>
