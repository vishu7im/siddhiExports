---
import { howItWorks } from '../data/site';
---
<section class="section" id="how-it-works">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">How It Works</span>
      <h2>Send a parcel in 3 simple steps</h2>
    </div>
    <ol class="steps">
      {howItWorks.map((s) => (
        <li class="step">
          <span class="step__num">{s.step}</span>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    counter-reset: step;
    position: relative;
  }
  .step { text-align: center; padding: 0 0.5rem; }
  .step__num {
    width: 64px; height: 64px;
    display: grid; place-items: center;
    margin: 0 auto 1rem;
    border-radius: 50%;
    background: var(--navy);
    color: #fff;
    font-family: var(--font-head); font-weight: 700; font-size: 1.5rem;
    box-shadow: var(--shadow-md);
    position: relative; z-index: 1;
  }
  .step h3 { margin-bottom: 0.3rem; }
  .step p { color: var(--muted); margin: 0; }

  /* connecting line on desktop */
  @media (min-width: 721px) {
    .steps::before {
      content: '';
      position: absolute;
      top: 32px; left: 16.6%; right: 16.6%;
      height: 2px;
      background: repeating-linear-gradient(90deg, var(--orange) 0 8px, transparent 8px 18px);
    }
  }
  @media (max-width: 720px) {
    .steps { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
