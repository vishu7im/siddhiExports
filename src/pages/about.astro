---
import Layout from '../layouts/Layout.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

const values = [
  { icon: 'shield', title: 'Safe Handling', text: 'Careful packing and trusted carriers for every parcel.' },
  { icon: 'chat', title: 'Honest Support', text: 'Transparent communication from quote to delivery.' },
  { icon: 'tag', title: 'Affordable Rates', text: 'Fair, competitive pricing with no hidden surprises.' },
  { icon: 'truck', title: 'Timely Delivery', text: 'Reliable pickup and on-time international shipping.' },
];
---
<Layout
  title="About Us — Trusted Parcel Service in Kurukshetra"
  description="SiddhiExports is an international parcel & shipping service based in Kurukshetra, Haryana. We help families and students send parcels safely from India to the UK, Canada, USA, Australia & Europe."
  path="/about"
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">About SiddhiExports</span>
      <h1>Making international shipping simple & stress-free</h1>
    </div>
  </section>

  <section class="section">
    <div class="container about__body">
      <p>
        <strong>SiddhiExports</strong> is an international parcel and shipping service based in
        {site.address.city}, {site.address.state}, India.
      </p>
      <p>
        We help families, students, and individuals send parcels safely from India to countries around
        the world — including the UK, Canada, USA, Australia, and Europe.
      </p>
      <p class="about__mission">
        Our mission is simple: to provide affordable, reliable, and hassle-free international parcel
        services with honest support and trusted delivery partners.
      </p>
      <p>
        We focus on customer satisfaction, safe handling, transparent communication, and timely delivery.
        Whether you are sending food items, clothes, documents, medicines, or personal belongings, our
        team is here to make international shipping simple and stress-free.
      </p>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">What We Stand For</span>
        <h2>Our promise to you</h2>
      </div>
      <div class="grid grid-2 about__values">
        {values.map((v) => (
          <div class="card about__value">
            <span class="icon-badge"><Icon name={v.icon} /></span>
            <div>
              <h3>{v.title}</h3>
              <p>{v.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA />
</Layout>

<style>
  .page-hero {
    background: radial-gradient(900px 400px at 75% -20%, #eaf3fa, transparent), var(--bg-soft);
    padding-block: clamp(2.5rem, 6vw, 4rem);
    text-align: center;
  }
  .about__body { max-width: 720px; margin-inline: auto; font-size: 1.12rem; }
  .about__mission {
    border-left: 4px solid var(--orange);
    background: var(--orange-100);
    padding: 1rem 1.3rem;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-weight: 500;
    color: var(--navy);
  }
  .about__value { display: flex; gap: 1rem; align-items: flex-start; }
  .about__value .icon-badge { margin-bottom: 0; flex: none; }
  .about__value h3 { margin-bottom: 0.2rem; }
  .about__value p { color: var(--muted); margin: 0; }
</style>
