---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { services } from '../data/site';
---
<Layout
  title="Services — International Parcel, Food & Document Shipping"
  description="SiddhiExports services: international parcel shipping, Indian food item shipping, document courier, clothes & personal items, student parcel services and bulk shipping support."
  path="/services"
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Our Services</span>
      <h1>International shipping services from India</h1>
      <p>Whatever you need to send abroad, we handle it safely — with doorstep pickup, honest rates and tracking support.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {services.map((s) => <ServiceCard icon={s.icon} title={s.title} text={s.text} />)}
      </div>
    </div>
  </section>

  <FinalCTA />
</Layout>

<style>
  .page-hero {
    background: radial-gradient(900px 400px at 75% -20%, #eaf3fa, transparent), var(--bg-soft);
    padding-block: clamp(2.5rem, 6vw, 4rem);
    text-align: center;
  }
  .page-hero p { color: var(--muted); max-width: 60ch; margin-inline: auto; font-size: 1.1rem; }
</style>
