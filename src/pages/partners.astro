---
import Layout from '../layouts/Layout.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Icon from '../components/Icon.astro';
import { partners } from '../data/site';
---
<Layout
  title="Our Shipping Network — Trusted Courier & Logistics Partners"
  description="SiddhiExports works with a trusted international courier and logistics network to provide reliable global parcel delivery from India."
  path="/partners"
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Our Network</span>
      <h1>Trusted International Courier & Logistics Network</h1>
      <p>
        We work with trusted international courier and logistics networks to provide reliable global
        parcel delivery services.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="partners">
        {partners.map((p) => (
          <div class="card partner">
            <span class="partner__logo" style={`color:${p.color}`}>{p.name}</span>
          </div>
        ))}
      </div>
      <p class="partners__note">
        <Icon name="shield" />
        SiddhiExports uses these courier channels and logistics support partners to ship your parcels
        worldwide. Carrier selection depends on your destination, parcel type and the best available rate.
      </p>
    </div>
  </section>

  <FinalCTA />
</Layout>

<style>
  .page-hero {
    background: radial-gradient(900px 400px at 75% -20%, #eaf3fa, transparent), var(--bg-soft);
    padding-block: clamp(2.5rem, 6vw, 4rem);
    text-align: center;
  }
  .page-hero p { color: var(--muted); max-width: 60ch; margin-inline: auto; font-size: 1.1rem; }

  .partners {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .partner { display: grid; place-items: center; min-height: 110px; }
  .partner__logo {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    letter-spacing: -0.02em;
  }
  .partners__note {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    max-width: 760px;
    margin: 2.2rem auto 0;
    color: var(--muted);
    background: var(--bg-soft);
    border-radius: var(--radius-sm);
    padding: 1.1rem 1.3rem;
    font-size: 0.95rem;
  }
  .partners__note :global(svg) { width: 22px; height: 22px; color: var(--orange-600); flex: none; margin-top: 2px; }

  @media (max-width: 700px) { .partners { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 420px) { .partners { grid-template-columns: 1fr; } }
</style>
